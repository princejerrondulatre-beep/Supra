        end

        -- Set theme
        function Window:SetTheme(themeName)
            Theme = self.Themes[themeName] or self.Themes.Ocean
            -- Update UI colors (simplified)
            MainFrame.BackgroundColor3 = Theme.Background
            TitleBar.BackgroundColor3 = Theme.Secondary
            TabContainer.BackgroundColor3 = Theme.Secondary
            -- etc. (full implementation would update all elements)
        end

        -- Discord clipboard
        function Window:CopyDiscordInvite()
            if config.DiscordInvite then
                setclipboard(config.DiscordInvite)
                -- Show notification
                local Notif = createInstance("TextLabel", {
                    Parent = MainFrame,
                    Text = "Discord invite copied!",
                    TextColor3 = Theme.Text,
                    BackgroundColor3 = Theme.Accent,
                    Size = UDim2.new(0, 200, 0, 30),
                    Position = UDim2.new(0.5, -100, 0, 10),
                    Font = Enum.Font.Gotham,
                    TextSize = 14,
                    ZIndex = 10
                })
                createInstance("UICorner", {Parent = Notif, CornerRadius = UDim.new(0, 4)})
                task.delay(2, function() Notif:Destroy() end)
            end
        end

        self.Window = Window
    end

    return Window
end

return SupraUI
