-- // Utility Functions
local function createInstance(className, properties)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        instance[prop] = value
    end
    return instance
end

local function tweenObject(object, properties, duration)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(object, tweenInfo, properties)
    tween:Play()
    return tween
end

-- // Key System (Rayfield‑style)
local ValidKeys = {"SupraUI-ExampleKey", "YourSecretKey123"} -- Hardcoded or fetch from GitHub
local KeyValidated = false

function SupraUI:SetKey(key)
    table.insert(ValidKeys, key)
end

function SupraUI:ValidateKey(inputKey)
    for _, valid in ipairs(ValidKeys) do
        if inputKey == valid then
            KeyValidated = true
            return true
        end
    end
    return false
end

